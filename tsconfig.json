{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": false,
    "noUncheckedIndexedAccess": false,
    "useDefineForClassFields": false,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts"
  ]
}
